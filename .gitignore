# ====================================================================
# 1. Binaries and Build Artifacts (Factor V: Build, Release, Run)
# ====================================================================
# Ignore the compiled Go binary
bin/
server
*.exe
*.dll
*.so
*.dylib

# ====================================================================
# 2. Environment and Secrets (Factor III: Config - CRITICAL)
# ====================================================================
# NEVER commit your actual secrets
.env
.env.local
*.secret
credentials.json

# Keep the example template so others know which keys are needed
!.env.example

# ====================================================================
# 3. Go Specifics
# ====================================================================
# Ignore test coverage reports
*.out
*.test
coverage.txt

# ====================================================================
# 4. Node.js / Frontend (web/ folder)
# ====================================================================
# Ignore the massive node_modules folder
web/node_modules/
web/.pnp
web/.pnp.js

# Ignore frontend build outputs (they are generated by your CI/CD)
web/dist/
web/build/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ====================================================================
# 5. OS and IDE Specifics
# ====================================================================
.DS_Store
.idea/
.vscode/
*.swp
*.swo
.zed/

# ====================================================================
# 6. Containers and Tooling
# ====================================================================
.docker/